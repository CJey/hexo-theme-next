// CSS Style Guide: https://codeguide.co/#css

// https://stylus-lang.com/docs/keyframes.html
vendors = official;

$scheme = hexo-config('scheme') ? hexo-config('scheme') : 'Muse';


// Variables Layer
// --------------------------------------------------
@import '_variables/base';
@import '_variables/' + $scheme;
for $inject_variable in hexo-config('injects.variable')
  @import $inject_variable;

// Mixins Layer
// --------------------------------------------------
@import '_mixins';
for $inject_mixin in hexo-config('injects.mixin')
  @import $inject_mixin;

// Dark mode colors
// --------------------------------------------------
@import '_colors';

// Common Layer
// --------------------------------------------------

// Scaffolding
@import '_common/scaffolding';

// Layout
@import '_common/outline';

// Components
@import '_common/components';


// Schemes Layer
// --------------------------------------------------
@import '_schemes/' + $scheme;


// Custom Layer
// --------------------------------------------------
for $inject_style in hexo-config('injects.style')
  @import $inject_style;


// Site-local customizations
// --------------------------------------------------

// Hide the decorative lines around site title.
.logo-line-before, .logo-line-after, .brand .logo-line
  display none

// Larger, plain site title — no underline animation, no border decoration.
.site-meta .brand
  background transparent
  padding 0
  border none

// Specificity needs to match Mist scheme's `.site-meta .site-title { font-weight: bolder }`.
.site-meta .site-title
  font-size 32px
  font-weight 400
  line-height 1.2
  letter-spacing 2px

// Slightly smaller body text overall.
body
  font-size 14px

// A touch larger post titles.
.post-title
  font-size 1.87em

// Brand block: keep title left, push nav to the right.
.site-brand-container
  display flex
  align-items center
  justify-content space-between

// Right-align main nav items inline next to title.
.site-nav
  display flex
  justify-content flex-end

.main-menu
  display flex
  flex-wrap wrap
  justify-content flex-end
  padding 0
  margin 0

.main-menu .menu-item
  margin 0 8px

.main-menu .menu-item a
  padding 6px 4px

// Heading hierarchy: NexT 8 default gradient (base 1.625em, step 0.125em)
// is too compressed — visually almost no difference between h2 and h3.
// Override with a wider scale (Major Third ≈ 1.25 ratio).
.post-body
  h1
    font-size 1.9em
    margin 1.4em 0 0.6em

  h2
    font-size 1.55em
    margin 1.6em 0 0.7em
    padding-bottom 0.25em
    border-bottom 1px solid var(--border-color)

  h3
    font-size 1.28em
    margin 1.3em 0 0.5em

  h4
    font-size 1.1em
    font-weight 600
    margin 1.1em 0 0.4em

  h5
    font-size 1em
    margin 1em 0 0.3em

  h6
    font-size 0.92em
    opacity 0.85
    margin 1em 0 0.3em

